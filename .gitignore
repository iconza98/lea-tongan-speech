.env
.env.*
*.env
service-account.json
*service-account*.json
FIREBASE_SERVICE_ACCOUNT_*.json
google-services.json
GoogleService-Info.plist
*.pem
*.key
.firebaserc.local

# =============================================================================
#  Corpus audio — large + license-sensitive. Lives in the Storage bucket and
#  the published Hugging Face Dataset, NOT in git. (Also stops UCLA/NCEA
#  eval audio from ever being committed — it is reference-only, never rehosted.)
# =============================================================================
/data/corpus/
/eval/**/gold-audio/
# UCLA/NCEA reference data — CC BY-NC-SA / BY-NC, eval-only, NEVER committed
ucla-lexicon.json
ncea-*.json
**/reference-data/
*.wav
*.mp3
*.flac
*.webm
*.ogg
*.m4a

# =============================================================================
#  Model weights / checkpoints — distributed via Hugging Face, not git.
# =============================================================================
/model/**/checkpoints/
/model/**/weights/
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.onnx

